#!/usr/bin/env python3
"""
taskman — Durable task manager for OpenClaw agents.

File-based task persistence. Survives gateway restarts, subagent death, and timeouts.
Tasks checkpoint progress to disk. New subagents can resume incomplete work.

Usage:
    taskman create --name "Research leads" --description "Find 100 Shopify stores" [--priority high]
    taskman list [--status pending|running|done|failed|stalled]
    taskman get <task_id>
    taskman update <task_id> --status running [--progress 45] [--checkpoint '{"leads_found": 23}']
    taskman checkpoint <task_id> --data '{"key": "value"}'
    taskman append <task_id> --output "Found 5 stores in AZ batch"
    taskman complete <task_id> [--result "path/to/output.csv"]
    taskman fail <task_id> --reason "Exa API rate limited"
    taskman resume  # list all resumable (running/stalled) tasks
    taskman stale   # mark running tasks with no update in 10min as stalled
"""

import argparse
import json
import os
import sys
import time
import uuid
from datetime import datetime, timezone
from pathlib import Path

TASKS_DIR = Path(os.environ.get("TASKMAN_DIR", os.path.expanduser("~/.openclaw/workspace/tasks")))
TASKS_DIR.mkdir(parents=True, exist_ok=True)

def now_iso():
    return datetime.now(timezone.utc).isoformat()

def task_path(task_id):
    return TASKS_DIR / f"{task_id}.json"

def load_task(task_id):
    p = task_path(task_id)
    if not p.exists():
        print(f"Error: task {task_id} not found", file=sys.stderr)
        sys.exit(1)
    return json.loads(p.read_text())

def save_task(task):
    task["updated_at"] = now_iso()
    task_path(task["id"]).write_text(json.dumps(task, indent=2))

def all_tasks():
    tasks = []
    for f in TASKS_DIR.glob("*.json"):
        try:
            tasks.append(json.loads(f.read_text()))
        except:
            pass
    return sorted(tasks, key=lambda t: t.get("created_at", ""), reverse=True)

def cmd_create(args):
    task_id = str(uuid.uuid4())[:8]
    task = {
        "id": task_id,
        "name": args.name,
        "description": args.description or "",
        "status": "pending",
        "priority": args.priority or "normal",
        "progress": 0,
        "checkpoint": {},
        "output_log": [],
        "result": None,
        "error": None,
        "created_at": now_iso(),
        "updated_at": now_iso(),
        "started_at": None,
        "completed_at": None,
        "subagent_id": None,
    }
    save_task(task)
    print(json.dumps(task, indent=2))

def cmd_list(args):
    tasks = all_tasks()
    if args.status:
        tasks = [t for t in tasks if t["status"] == args.status]
    if not tasks:
        print("No tasks found.")
        return
    for t in tasks:
        prog = f" [{t['progress']}%]" if t['progress'] > 0 else ""
        print(f"  {t['id']}  {t['status']:8s}{prog}  {t['priority']:6s}  {t['name']}")

def cmd_get(args):
    print(json.dumps(load_task(args.task_id), indent=2))

def cmd_update(args):
    task = load_task(args.task_id)
    if args.status:
        task["status"] = args.status
        if args.status == "running" and not task["started_at"]:
            task["started_at"] = now_iso()
    if args.progress is not None:
        task["progress"] = args.progress
    if args.checkpoint:
        task["checkpoint"].update(json.loads(args.checkpoint))
    if args.subagent_id:
        task["subagent_id"] = args.subagent_id
    save_task(task)
    print(json.dumps(task, indent=2))

def cmd_checkpoint(args):
    task = load_task(args.task_id)
    task["checkpoint"].update(json.loads(args.data))
    save_task(task)
    print(f"Checkpoint saved for {args.task_id}")

def cmd_append(args):
    task = load_task(args.task_id)
    task["output_log"].append({"ts": now_iso(), "text": args.output})
    save_task(task)
    print(f"Output appended to {args.task_id}")

def cmd_complete(args):
    task = load_task(args.task_id)
    task["status"] = "done"
    task["progress"] = 100
    task["completed_at"] = now_iso()
    if args.result:
        task["result"] = args.result
    save_task(task)
    print(json.dumps(task, indent=2))

def cmd_fail(args):
    task = load_task(args.task_id)
    task["status"] = "failed"
    task["error"] = args.reason
    task["completed_at"] = now_iso()
    save_task(task)
    print(json.dumps(task, indent=2))

def cmd_resume(args):
    tasks = [t for t in all_tasks() if t["status"] in ("running", "stalled", "pending")]
    if not tasks:
        print("No resumable tasks.")
        return
    for t in tasks:
        cp = json.dumps(t["checkpoint"]) if t["checkpoint"] else "none"
        print(f"  {t['id']}  {t['status']:8s}  {t['progress']:3d}%  {t['name']}")
        if t["checkpoint"]:
            print(f"           checkpoint: {cp[:120]}")
        if t["output_log"]:
            last = t["output_log"][-1]["text"]
            print(f"           last output: {last[:120]}")

def cmd_stale(args):
    stale_threshold = 600  # 10 minutes
    now = time.time()
    count = 0
    for t in all_tasks():
        if t["status"] == "running":
            updated = datetime.fromisoformat(t["updated_at"]).timestamp()
            if now - updated > stale_threshold:
                t["status"] = "stalled"
                save_task(t)
                print(f"  Stalled: {t['id']} — {t['name']}")
                count += 1
    if count == 0:
        print("No stale tasks.")

def main():
    parser = argparse.ArgumentParser(prog="taskman", description="Durable task manager")
    sub = parser.add_subparsers(dest="command")

    p = sub.add_parser("create")
    p.add_argument("--name", required=True)
    p.add_argument("--description", default="")
    p.add_argument("--priority", default="normal", choices=["low", "normal", "high", "critical"])

    p = sub.add_parser("list")
    p.add_argument("--status", choices=["pending", "running", "done", "failed", "stalled"])

    p = sub.add_parser("get")
    p.add_argument("task_id")

    p = sub.add_parser("update")
    p.add_argument("task_id")
    p.add_argument("--status", choices=["pending", "running", "done", "failed", "stalled"])
    p.add_argument("--progress", type=int)
    p.add_argument("--checkpoint", help="JSON string to merge into checkpoint")
    p.add_argument("--subagent-id")

    p = sub.add_parser("checkpoint")
    p.add_argument("task_id")
    p.add_argument("--data", required=True, help="JSON string")

    p = sub.add_parser("append")
    p.add_argument("task_id")
    p.add_argument("--output", required=True)

    p = sub.add_parser("complete")
    p.add_argument("task_id")
    p.add_argument("--result", help="Path to output file or summary")

    p = sub.add_parser("fail")
    p.add_argument("task_id")
    p.add_argument("--reason", required=True)

    p = sub.add_parser("resume")
    p = sub.add_parser("stale")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(1)

    globals()[f"cmd_{args.command}"](args)

if __name__ == "__main__":
    main()
